# Core
NODE_ENV=production
APP_NAME=radiant
TZ=America/Los_Angeles

# Public URLs
ADMIN_PUBLIC_URL=https://admin.<your-domain>
API_PUBLIC_URL=https://api.<your-domain>
WP_ORIGIN=https://<your-wordpress-domain>

# Postgres
POSTGRES_DB=radiant
POSTGRES_USER=radiant
POSTGRES_PASSWORD=replace_me
DATABASE_URL=postgres://radiant:replace_me@postgres:5432/radiant

# Directus
DIRECTUS_KEY=replace_me
DIRECTUS_SECRET=replace_me
DIRECTUS_ADMIN_EMAIL=admin@<your-domain>
DIRECTUS_ADMIN_PASSWORD=replace_me
DIRECTUS_URL=http://directus:8055

# Cloudflare Tunnel
CF_TUNNEL_ID=replace_me
CF_TUNNEL_CREDENTIALS=/run/secrets/cf_tunnel.json

# Now Playing resolver defaults
NOW_PLAYING_CONFIDENCE_MIN=0.80
NOW_PLAYING_FRESH_SECONDS=30

# API edge controls
CORS_ALLOWED_ORIGINS=https://<your-wordpress-domain>,https://admin.<your-domain>,http://localhost:8080
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
RADIANT_ADMIN_TOKEN=replace_me
RADIANT_ADMIN_TITLE=KAAD-lp Admin
RADIANT_PUBLIC_STATUS_TITLE=Public Status
RADIANT_ADMIN_API_BASE_URL=https://api.<your-domain>

# Optional future ACRCloud integration
ACRCLOUD_ACCESS_KEY=
ACRCLOUD_ACCESS_SECRET=
ACRCLOUD_HOST=
ACRCLOUD_CALLBACK_SECRET=replace_me
ACRCLOUD_CALLBACK_TOKEN=replace_me
ACRCLOUD_DEDUPE_SECONDS=120
ACRCLOUD_EXPECTED_PROJECT_ID=replace_me_stream_id

# Optional Icecast metadata defaults (runtime config persists in Docker volume)
ICECAST_META_CONFIG_PATH=/app/data/icecast-meta-config.json
ICECAST_META_ENABLED=false
ICECAST_META_SCHEME=http
ICECAST_META_HOST=
ICECAST_META_PORT=8000
ICECAST_META_MOUNT=stream
ICECAST_META_USERNAME=source
ICECAST_META_PASSWORD=
ICECAST_LISTENER_HISTORY_PATH=/app/data/icecast-listener-history.json
ICECAST_GEO_CACHE_PATH=/app/data/icecast-geo-cache.json
ICECAST_SNAPSHOT_CACHE_MS=20000
ICECAST_GEO_CACHE_SUCCESS_TTL_MS=2592000000
ICECAST_GEO_CACHE_FAILURE_TTL_MS=300000
